{
  "manifest_version": 3,
  "name": "Page Monitor",
  "version": "1.0.1",
  "description": "Monitor content changes on any webpage. Get notified instantly when changes are detected.",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "notifications",
    "offscreen",
    "scripting",
    "tabs"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_badge_background_color": "#FF4444"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
